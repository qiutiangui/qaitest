# qaitest智测平台 环境配置文件
# 请根据实际情况修改以下配置项

# ============ 数据库配置【必填】============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=qaitest

# ============ Milvus配置【必填】============
# 向量数据库，用于RAG知识检索
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=qaitest_knowledge

# ============ 部署配置 ============
# DOMAIN：域名，如 example.com 或 test.example.com
# SSL_EMAIL：SSL证书申请邮箱，用于接收证书到期提醒
# 生产环境有域名时必填，自动申请免费SSL证书
# 无域名或本地开发时留空，使用IP访问（无HTTPS）
# 示例：DOMAIN=example.com, SSL_EMAIL=admin@example.com
DOMAIN=
SSL_EMAIL=

# ============ 应用配置【选填】============
# 运行环境：development（本地开发）或 production（生产部署）
# 本地开发：APP_ENV=development, APP_DEBUG=true
# 生产部署：APP_ENV=production, APP_DEBUG=false
APP_ENV=development
APP_DEBUG=true

# 后端服务端口，一般无需修改
APP_PORT=8000
